# Your Sentry DSN (from your Sentry account)
VITE_SENTRY_DSN=

# Your Sentry organization (from your Sentry account)
VITE_SENTRY_ORG=

# Your Sentry project (from your Sentry account)
VITE_SENTRY_PROJECT=

# Your Sentry authentication token (from your Sentry account)
SENTRY_AUTH_TOKEN=

# Clerk configuration, get this key from your [Dashboard](dashboard.clerk.com)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET= # webhook signing secret from Clerk
CLERK_CONVEX_WEBHOOK_KEY= # shared secret; set this in both app and Convex env

# Mobile app environment
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Convex configuration, get this URL from your [Dashboard](dashboard.convex.dev)
CONVEX_DEPLOYMENT=dev:... # team: ..., project: ...
VITE_CONVEX_URL=https://... # e.g. https://my-convex-deployment.convex.cloud

VITE_CONVEX_SITE_URL=https://... # e.g. https://my-convex-deployment.convex.site

# PostHog analytics configuration
# Use your project API key and ingestion host (US: https://us.i.posthog.com, EU: https://eu.i.posthog.com)
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Base URL for OG images and absolute links. Set in dev so TanStack Router devtools
# can load og:image previews from the same origin (e.g. http://localhost:3000).
# Leave unset in production to use the canonical site URL.
# VITE_SITE_URL=http://localhost:3000

# Resend configuration, get this key from your [Resend Dashboard](https://resend.com/api-keys
RESEND_API_KEY=re_...

# Paddle billing configuration
# Client-side token for Paddle.js on /pay (test_... in sandbox, live_... in production)
VITE_PADDLE_CLIENT_TOKEN=
# Optional explicit environment override: sandbox | production
# VITE_PADDLE_ENV=sandbox
PADDLE_API_KEY= # Paddle API key (live_... or test_...)
PADDLE_SEASON_PASS_PRICE_ID=pri_...
PADDLE_WEBHOOK_SECRET= # endpoint secret from Paddle notifications
PADDLE_CONVEX_WEBHOOK_KEY= # shared secret; set this in both app and Convex env
# Optional override; defaults to https://api.paddle.com
# PADDLE_API_BASE=https://api.paddle.com
