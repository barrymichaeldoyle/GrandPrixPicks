{
  "name": "@grandprixpicks/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- convex dev",
    "deploy": "convex deploy --yes --typecheck disable",
    "email:dev": "email dev --dir convex/emails --port 3030",
    "lint": "pnpm exec oxlint -c ../../.oxlintrc.json convex",
    "lint:fix": "pnpm exec oxlint -c ../../.oxlintrc.json convex --fix",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "pnpm --dir ../.. exec oxfmt apps/backend",
    "format:check": "pnpm --dir ../.. exec oxfmt --check apps/backend",
    "check": "pnpm run format:check && pnpm run lint",
    "migrations": "node scripts/convex/run-migrations.mjs",
    "migrations:prod": "node scripts/convex/run-migrations.mjs --prod",
    "backfill:top5": "node scripts/convex/backfill-top5-scores.mjs",
    "backfill:top5:prod": "node scripts/convex/backfill-top5-scores.mjs --prod",
    "typecheck": "pnpm --dir ../.. --filter @grandprixpicks/shared typecheck && tsc --noEmit -p convex/tsconfig.json"
  },
  "dependencies": {
    "@convex-dev/resend": "0.2.3",
    "@grandprixpicks/shared": "workspace:*",
    "@react-email/components": "1.0.9",
    "@react-email/render": "2.0.4",
    "convex": "1.34.0",
    "dotenv-cli": "11.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.9",
    "@types/react": "19.2.14",
    "@types/web-push": "3.6.4",
    "react-email": "5.2.9",
    "typescript": "catalog:",
    "vitest": "4.1.0"
  }
}
