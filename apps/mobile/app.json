{
  "expo": {
    "name": "Grand Prix Picks",
    "slug": "grand-prix-picks",
    "scheme": "grandprixpicks",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#14b8a6"
        }
      ],
      "expo-apple-authentication",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "@sentry/react-native"
    ],
    "ios": {
      "bundleIdentifier": "com.barrymichaeldoyle.grandprixpicks",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.barrymichaeldoyle.grandprixpicks"
    },
    "extra": {
      "eas": {
        "projectId": "71791ac4-8281-4067-9b8d-f3773f6367b3"
      }
    },
    "owner": "barrymichaeldoyle"
  }
}
