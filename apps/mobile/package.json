{
  "name": "@grandprixpicks/mobile",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "expo start --dev-client --host lan",
    "dev:localhost": "expo start --dev-client --host localhost",
    "dev:tunnel": "expo start --dev-client --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot",
    "lint": "pnpm exec oxlint -c ../../.oxlintrc.json .",
    "lint:fix": "pnpm exec oxlint -c ../../.oxlintrc.json . --fix",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "pnpm --dir ../.. exec oxfmt apps/mobile",
    "format:check": "pnpm --dir ../.. exec oxfmt --check apps/mobile",
    "check": "pnpm run format:check && pnpm run lint"
  },
  "dependencies": {
    "@clerk/clerk-expo": "2.19.39",
    "@expo-google-fonts/orbitron": "0.4.2",
    "@expo/vector-icons": "15.1.1",
    "@grandprixpicks/shared": "workspace:*",
    "@react-navigation/bottom-tabs": "7.18.8",
    "@react-navigation/native": "7.3.8",
    "@react-navigation/native-stack": "7.17.10",
    "@sentry/react-native": "~7.11.0",
    "@tailwindcss/postcss": "^4.3.2",
    "clsx": "^2.1.1",
    "convex": "catalog:",
    "expo": "~57.0.4",
    "expo-apple-authentication": "~57.0.0",
    "expo-application": "~57.0.0",
    "expo-auth-session": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-device": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-localization": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-secure-store": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "nativewind": "5.0.0-preview.2",
    "posthog-react-native": "^4.54.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-css": "3.0.7",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "2.32.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "typescript"
      ]
    }
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "typescript": "catalog:",
    "vitest": "4.1.10"
  },
  "version": "1.0.0"
}
