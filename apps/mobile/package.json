{
  "name": "@grandprixpicks/mobile",
  "private": true,
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec oxlint -c ../../.oxlintrc.json .",
    "lint:fix": "pnpm exec oxlint -c ../../.oxlintrc.json . --fix",
    "fix": "pnpm run format && pnpm run lint:fix",
    "format": "pnpm --dir ../.. exec oxfmt apps/mobile",
    "format:check": "pnpm --dir ../.. exec oxfmt --check apps/mobile",
    "check": "pnpm run format:check && pnpm run lint"
  },
  "dependencies": {
    "@clerk/clerk-expo": "2.19.31",
    "@expo-google-fonts/orbitron": "0.4.2",
    "@expo/vector-icons": "15.1.1",
    "@grandprixpicks/shared": "workspace:*",
    "@react-navigation/bottom-tabs": "7.15.5",
    "@react-navigation/native": "7.1.33",
    "@react-navigation/native-stack": "7.14.4",
    "convex": "catalog:",
    "expo": "~55.0.12",
    "expo-auth-session": "~55.0.12",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.13",
    "expo-notifications": "~55.0.17",
    "expo-secure-store": "~55.0.12",
    "expo-status-bar": "~55.0.5",
    "expo-web-browser": "~55.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-worklets": "0.7.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "typescript": "~5.9.2"
  },
  "version": "1.0.0"
}
