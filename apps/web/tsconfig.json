{
  "extends": "../../tsconfig.base.json",
  "references": [{ "path": "../../packages/shared" }],
  "include": ["**/*.ts", "**/*.tsx", "prettier.config.js", "vite.config.ts"],

  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
