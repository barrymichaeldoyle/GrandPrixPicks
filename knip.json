{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreIssues": {
    "apps/web/src/integrations/tanstack-query/root-provider.tsx": ["exports"]
  },
  "workspaces": {
    "apps/web": {
      "entry": [
        "src/start.ts",
        "instrument.server.mjs",
        "server/routes/**/*.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "server/**/*.{ts,tsx}"],
      "ignoreFiles": [
        "src/components/RaceCardSkeleton.tsx",
        "src/lib/og/fonts.ts",
        "src/lib/og/renderer.ts",
        "src/lib/og/styles.ts",
        "src/lib/og/templates.ts"
      ],
      "ignoreDependencies": [
        "@tanstack/router-plugin",
        "tailwindcss"
      ],
      "ignoreBinaries": ["cloudflared"]
    },
    "apps/backend": {
      "entry": ["convex/**/*.ts"],
      "project": ["convex/**/*.ts"],
      "ignoreDependencies": [
        "@react-email/components",
        "@react-email/preview-server"
      ]
    },
    "apps/mobile": {
      "entry": ["App.tsx"],
      "project": ["**/*.{ts,tsx,js,cjs}"],
      "ignoreDependencies": ["expo-updates"]
    },
    "packages/shared": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["vitest"]
    }
  }
}
