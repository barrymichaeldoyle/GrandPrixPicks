{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreIssues": {
    "apps/web/src/integrations/tanstack-query/root-provider.tsx": ["exports"]
  },
  "workspaces": {
    "apps/web": {
      "entry": ["src/start.ts", "instrument.server.mjs"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreFiles": [
        "src/components/RaceCardSkeleton.tsx",
        "src/lib/og/fonts.ts",
        "src/lib/og/renderer.ts",
        "src/lib/og/styles.ts",
        "src/lib/og/templates.ts"
      ],
      "ignoreDependencies": [
        "@tanstack/router-plugin",
        "tailwindcss",
        "babel-plugin-react-compiler"
      ],
      "ignoreBinaries": ["cloudflared"]
    },
    "apps/backend": {
      "entry": ["convex/**/*.ts"],
      "project": ["convex/**/*.ts"],
      "ignoreDependencies": ["@react-email/components"]
    },
    "apps/mobile": {
      "entry": ["App.tsx", "metro.config.cjs"],
      "project": ["**/*.{ts,tsx,js,cjs}"],
      "ignoreDependencies": [
        "expo-updates",
        "react-native-web",
        "react-dom",
        "@expo/metro-runtime"
      ]
    },
    "packages/shared": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["vitest"]
    }
  }
}
