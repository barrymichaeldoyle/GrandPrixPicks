{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreFiles": [".agents/**"],
  "ignoreIssues": {
    "apps/web/src/integrations/tanstack-query/root-provider.tsx": ["exports"],
    "apps/web/src/lib/og/templates.ts": ["exports"]
  },
  "workspaces": {
    "apps/web": {
      "entry": [
        "src/start.ts",
        "instrument.server.mjs",
        "server/routes/**/*.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "server/**/*.{ts,tsx}"],
      "ignoreFiles": ["src/components/RaceCardSkeleton.tsx"],
      "ignoreDependencies": ["@tanstack/router-plugin", "tailwindcss"],
      "ignoreBinaries": ["cloudflared"]
    },
    "apps/backend": {
      "entry": ["convex/**/*.ts"],
      "project": ["convex/**/*.ts"]
    },
    "apps/mobile": {
      "entry": ["App.tsx"],
      "project": ["**/*.{ts,tsx,js,cjs}"],
      "ignoreFiles": ["babel.config.cjs"],
      "ignoreDependencies": ["expo-updates", "tailwind-merge", "clsx"],
      "ignore": ["src/tw/index.tsx", "plugins/*.cjs"]
    },
    "packages/shared": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["vitest"]
    }
  }
}
