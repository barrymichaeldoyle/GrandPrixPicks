{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/start.ts", "eslint.config.js", "instrument.server.mjs"],
  "project": ["src/**/*.{ts,tsx}", "convex/**/*.{ts,tsx}"],
  "ignoreFiles": [
    "src/routeTree.gen.ts",
    "convex/_generated",
    "src/components/RaceCardSkeleton.tsx",
    "src/lib/og/fonts.ts",
    "src/lib/og/renderer.ts",
    "src/lib/og/styles.ts",
    "src/lib/og/templates.ts",
    "src/stories/router-decorator.tsx"
  ],
  "ignoreDependencies": [
    "@tanstack/router-plugin",
    "tailwindcss",
    "babel-plugin-react-compiler",
    "@react-email/preview-server",
    "satori"
  ],
  "ignoreBinaries": ["eslint"],
  "ignoreIssues": {
    "src/integrations/tanstack-query/root-provider.tsx": ["exports"]
  },
  "convex": {
    "entry": ["convex/**/*.{ts,tsx}"]
  }
}
