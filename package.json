{
  "name": "grand-prix-picks",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n v,c \"pnpm run dev:vite\" \"pnpm run dev:convex\"",
    "dev:public": "concurrently -n app,t \"pnpm run dev\" \"pnpm run dev:tunnel\"",
    "dev:tunnel": "cloudflared tunnel run --url http://localhost:3000 grandprixpicks-dev",
    "dev:vite": "dotenv -e .env.local -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000 --strictPort\"",
    "dev:convex": "convex dev",
    "build": "node scripts/render-logo-png.mjs && node scripts/render-og-default-png.mjs && vite build && cp instrument.server.mjs .output/server",
    "build:cf": "node scripts/render-logo-png.mjs && node scripts/render-og-default-png.mjs && CF_PAGES=1 vite build",
    "preview": "vite preview",
    "preview:cf": "pnpm build:cf && wrangler pages dev .output/public",
    "deploy": "pnpm build:cf && wrangler pages deploy .output/public",
    "email:dev": "email dev --dir convex/emails --port 3030",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm exec eslint",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm test:ci && pnpm knip",
    "fix": "prettier --write . && eslint --fix .",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "convex:migrations": "node scripts/convex/run-migrations.mjs",
    "convex:migrations:prod": "node scripts/convex/run-migrations.mjs --prod",
    "knip": "knip",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
  },
  "dependencies": {
    "@clerk/clerk-react": "5.61.3",
    "@clerk/tanstack-react-start": "0.29.8",
    "@clerk/themes": "2.4.57",
    "@convex-dev/resend": "0.2.3",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@react-email/components": "1.0.8",
    "@react-email/render": "2.0.4",
    "@resvg/resvg-wasm": "2.6.2",
    "@sentry/tanstackstart-react": "10.40.0",
    "@tailwindcss/vite": "4.2.1",
    "@tanstack/react-devtools": "0.9.6",
    "@tanstack/react-query": "5.90.21",
    "@tanstack/react-query-devtools": "5.91.3",
    "@tanstack/react-router": "1.163.3",
    "@tanstack/react-router-devtools": "1.163.3",
    "@tanstack/react-router-ssr-query": "1.163.3",
    "@tanstack/react-start": "1.166.1",
    "@tanstack/router-plugin": "1.164.0",
    "@types/web-push": "^3.6.4",
    "canvas-confetti": "1.9.4",
    "convex": "1.32.0",
    "dotenv-cli": "11.0.0",
    "framer-motion": "12.34.3",
    "lucide-react": "0.575.0",
    "nitro": "npm:nitro-nightly@latest",
    "posthog-js": "^1.356.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "satori": "0.19.2",
    "tailwindcss": "4.2.1",
    "vite-tsconfig-paths": "6.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.9",
    "@sentry/vite-plugin": "5.1.1",
    "@storybook/addon-vitest": "10.2.13",
    "@storybook/react": "10.2.13",
    "@storybook/react-vite": "10.2.13",
    "@tanstack/devtools-vite": "0.5.2",
    "@tanstack/eslint-config": "0.4.0",
    "@types/canvas-confetti": "1.9.0",
    "@types/node": "25.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "jsdom": "28.1.0",
    "knip": "5.85.0",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "react-email": "5.2.9",
    "storybook": "10.2.13",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "wrangler": "4.69.0"
  }
}
