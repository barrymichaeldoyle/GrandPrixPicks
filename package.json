{
  "name": "grand-prix-picks",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @grandprixpicks/web dev",
    "dev:web": "pnpm --filter @grandprixpicks/web dev",
    "dev:mobile": "pnpm --filter @grandprixpicks/mobile exec expo start",
    "dev:backend": "pnpm --filter @grandprixpicks/backend dev",
    "dev:convex": "pnpm --filter @grandprixpicks/backend dev",
    "dev:public": "pnpm --filter @grandprixpicks/web dev:public",
    "build": "pnpm --filter @grandprixpicks/web build",
    "build:cf": "pnpm --filter @grandprixpicks/web build:cf",
    "preview": "pnpm --filter @grandprixpicks/web preview",
    "preview:cf": "pnpm --filter @grandprixpicks/web preview:cf",
    "deploy": "pnpm --filter @grandprixpicks/web deploy",
    "deploy:backend": "pnpm --filter @grandprixpicks/backend deploy",
    "deploy:convex": "pnpm --filter @grandprixpicks/backend deploy",
    "email:dev": "pnpm --filter @grandprixpicks/backend email:dev",
    "test": "pnpm --filter @grandprixpicks/web test",
    "test:ci": "pnpm --filter @grandprixpicks/web test:ci",
    "typecheck": "pnpm --filter @grandprixpicks/shared typecheck && pnpm --filter @grandprixpicks/web typecheck && pnpm --filter @grandprixpicks/backend typecheck",
    "lint": "pnpm --filter @grandprixpicks/web lint && pnpm --filter @grandprixpicks/backend lint",
    "lint:fix": "pnpm --filter @grandprixpicks/web lint:fix && pnpm --filter @grandprixpicks/backend lint:fix",
    "knip": "knip",
    "ci:check": "pnpm lint && pnpm typecheck && pnpm test:ci && pnpm knip",
    "storybook": "pnpm --filter @grandprixpicks/web storybook",
    "build-storybook": "pnpm --filter @grandprixpicks/web build-storybook",
    "ios": "pnpm --filter @grandprixpicks/mobile exec expo start --ios",
    "android": "pnpm --filter @grandprixpicks/mobile exec expo start --android",
    "fix": "pnpm exec prettier --write . && pnpm lint:fix",
    "format": "pnpm exec prettier",
    "check": "pnpm exec prettier --check . && pnpm lint",
    "convex:migrations": "pnpm --filter @grandprixpicks/backend migrations",
    "convex:migrations:prod": "pnpm --filter @grandprixpicks/backend migrations:prod",
    "start": "pnpm --filter @grandprixpicks/web start"
  },
  "devDependencies": {
    "eslint": "catalog:",
    "knip": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:"
  },
  "packageManager": "pnpm@10.32.1"
}
